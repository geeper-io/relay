---
const securityItems = [
  {
    title: "HMAC-signed OAuth state",
    desc: "Stateless SSO — no server-side session storage, safe across replicas",
  },
  {
    title: "API key hashing",
    desc: "Keys stored as SHA-256 hashes — compromised DB cannot leak secrets",
  },
  {
    title: "PII never leaves your network",
    desc: "Entities scrubbed before inference, restored locally in responses",
  },
  {
    title: "Content policy enforcement",
    desc: "Block prompt injection and jailbreak patterns at the gateway",
  },
  {
    title: "Non-root containers",
    desc: "runAsUser 1001, allowPrivilegeEscalation: false, drop ALL capabilities",
  },
  {
    title: "Secret auto-rotation safe",
    desc: "Master key preserved across helm upgrades via lookup() + resource-policy: keep",
  },
];

const observabilityItems = [
  {
    title: "Prometheus metrics",
    desc: "/metrics endpoint with ServiceMonitor for Kube-Prometheus-Stack",
  },
  {
    title: "Structured logging",
    desc: "JSON logs with request ID, user, model, tokens, latency per request",
  },
  {
    title: "Daily usage materialization",
    desc: "PostgreSQL materialized view refreshed hourly — zero-cost queries",
  },
  {
    title: "Team leaderboards",
    desc: "Cost, token, and request rankings across teams and users",
  },
  {
    title: "Langfuse integration",
    desc: "Full trace export: prompt, completion, latency, cost per request",
  },
  {
    title: "Health endpoints",
    desc: "/healthz (liveness) and /readyz (readiness) — Kubernetes native",
  },
];
---

<section class="py-24 bg-slate-900/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-slate-50 mb-4">Enterprise ready</h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        Security and observability built in from day one — not bolted on.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <!-- Security card -->
      <div class="p-8 rounded-2xl bg-slate-900 border border-slate-800">
        <div class="flex items-center gap-3 mb-6">
          <div class="p-2.5 rounded-xl bg-red-500/10">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f87171" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <polyline points="9 12 11 14 15 10"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-100">Security</h3>
            <p class="text-xs text-slate-500">Defence in depth</p>
          </div>
        </div>
        <ul class="space-y-4">
          {
            securityItems.map((item) => (
              <li class="flex gap-3">
                <svg class="mt-0.5 shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <circle cx="8" cy="8" r="7" stroke="#374151" stroke-width="1"/>
                  <path d="M5 8l2 2 4-4" stroke="#34d399" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <div>
                  <div class="text-sm font-medium text-slate-300">{item.title}</div>
                  <div class="text-xs text-slate-500 mt-0.5">{item.desc}</div>
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Observability card -->
      <div class="p-8 rounded-2xl bg-slate-900 border border-slate-800">
        <div class="flex items-center gap-3 mb-6">
          <div class="p-2.5 rounded-xl bg-blue-600/10">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-100">Observability</h3>
            <p class="text-xs text-slate-500">Know what's happening</p>
          </div>
        </div>
        <ul class="space-y-4">
          {
            observabilityItems.map((item) => (
              <li class="flex gap-3">
                <svg class="mt-0.5 shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <circle cx="8" cy="8" r="7" stroke="#374151" stroke-width="1"/>
                  <path d="M5 8l2 2 4-4" stroke="#818cf8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <div>
                  <div class="text-sm font-medium text-slate-300">{item.title}</div>
                  <div class="text-xs text-slate-500 mt-0.5">{item.desc}</div>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
